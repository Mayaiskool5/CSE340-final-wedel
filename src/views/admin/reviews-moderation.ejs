<%- include('../partials/header') %>
<main class="admin-container">
    <h1>Review Moderation</h1>

    <div class="card shadow-sm">
        <table class="service-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Vehicle</th>
                    <th>Rating</th>
                    <th>Comment</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% reviews.forEach(review => { %>
                    <tr>
                        <td><%= review.user_name %></td>
                        <td><%= review.make %> <%= review.model %></td>
                        <td><%= review.rating %> Stars</td>
                        <td><small><%= review.comment %></small></td>
                        <td>
                            <form action="/admin/reviews/delete/<%= review.id %>" method="POST">
                                <!-- Pass a redirect slug so the controller knows where to go -->
                                <input type="hidden" name="vehicle_slug" value="admin/reviews">
                                <button type="submit" class="btn-delete" onclick="return confirm('Delete this review?')">
                                    Remove
                                </button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</main>
<%- include('../partials/footer') %>
