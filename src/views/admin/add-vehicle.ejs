<%- include('../partials/header') %>
<main class="admin-form-container">
    <h1>Add New Inventory</h1>
    
    <form action="/admin/inventory/add" method="POST" class="styled-form">
        <div class="form-row">
            <div class="field">
                <label>Make</label>
                <input type="text" name="make" placeholder="e.g. Ford" required>
            </div>
            <div class="field">
                <label>Model</label>
                <input type="text" name="model" placeholder="e.g. F-150" required>
            </div>
            <div class="field">
                <label>Year</label>
                <input type="number" name="year" min="1900" max="2026" required>
            </div>
        </div>

        <div class="form-row">
            <div class="field">
                <label>Price ($)</label>
                <input type="number" name="price" step="0.01" required>
            </div>
            <div class="field">
                <label>Mileage</label>
                <input type="number" name="mileage">
            </div>
            <div class="field">
                <label>Category</label>
                <select name="category_id" required>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat.id %>"><%= cat.name %></option>
                    <% }) %>
                </select>
            </div>
        </div>

        <fieldset class="specs-section">
            <legend>Technical Specs (JSONB)</legend>
            <div class="form-row">
                <div class="field">
                    <label>Engine</label>
                    <input type="text" name="spec_engine" placeholder="e.g. 5.0L V8">
                </div>
                <div class="field">
                    <label>Transmission</label>
                    <input type="text" name="spec_trans" placeholder="e.g. 10-Speed Auto">
                </div>
                <div class="field">
                    <label>Fuel Type</label>
                    <input type="text" name="spec_fuel" placeholder="e.g. Gasoline">
                </div>
            </div>
        </fieldset>

        <div class="field">
            <label>Description</label>
            <textarea name="description" rows="4"></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Save Vehicle</button>
            <a href="/vehicle" class="btn-cancel">Cancel</a>
        </div>
    </form>
</main>
<%- include('../partials/footer') %>
