<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/main.css">
<main>
    <div class="vehicle-detail">
        <img 
            src="/images/vehicles/<%= vehicle.slug %>.jpg" 
            alt="Photo of <%= vehicle.name %>" 
            class="vehicle-detail-photo"
        >
        <h1><%= vehicle.name %></h1>
        <p><strong>Title:</strong> <%= vehicle.title %></p>
        <p><strong>Department:</strong> <%= vehicle.department %></p>
        <h2>Contact Information</h2>
        <p><strong>Office:</strong> <%= vehicle.office %></p>
        <p><strong>Phone:</strong> <%= vehicle.phone %></p>
        <p><strong>Email:</strong> <a href="mailto:<%= vehicle.email %>"><%= vehicle.email %></a></p>
    </div>

    <div class="navigation">
        <p><a href="/vehicles">&larr; Back to Vehicles</a></p>
    </div>
</main>
<%- include('../partials/footer') %>