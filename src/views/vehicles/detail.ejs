<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/main.css">
<ul>
    <% for (const [key, value] of Object.entries(vehicle.specs || {})) { %>
        <li><strong><%= key.charAt(0).toUpperCase() + key.slice(1) %>:</strong> <%= value %></li>
    <% } %>
</ul>
<main>
    <div class="vehicle-detail">
        <img 
            src="/images/vehicles/<%= vehicle.slug %>.jpg" 
            alt="Photo of <%= vehicle.make %> <%= vehicle.model %>" 
            class="vehicle-detail-photo"
        >
        <h1><%= vehicle.make %> <%= vehicle.model %></h1>
        <p><strong>Year:</strong> <%= vehicle.year %></p>
        <p><strong>Department:</strong> <%= vehicle.category_id %></p>
        <p><strong>Price:</strong> <%= vehicle.price %></p>
    </div>

    <div class="navigation">
        <p><a href="/vehicles">&larr; Back to Vehicles</a></p>
    </div>
</main>
<%- include('../partials/footer') %>