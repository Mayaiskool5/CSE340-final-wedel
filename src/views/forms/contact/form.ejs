<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/main.css">
<main>
    <h1>Contact Us</h1>
    <p>
        Have any questions on a vehicle? Need more information about our services? Fill out the form below and we'll get back to you as soon as possible!
    </p>

    <form method="POST" action="/contact" class="contact-form">
        <div class="form-group">
            <label for="subject">Subject</label>
            <input type="text" id="subject" name="subject" placeholder="What is this message about?" minlength="2" required>
        </div>

        <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="6" placeholder="Enter your phone number, the vehicle you're interested in, and info about what you are looking for." minlength="10" required></textarea>
        </div>

        <button type="submit">Send Message</button>
    </form>
</main>
<%- include('../../partials/footer') %>