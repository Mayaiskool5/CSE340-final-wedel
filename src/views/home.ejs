<%- include('partials/header') %>
<link rel="stylesheet" href="/css/main.css">

<main>
    <section class="text-center mb-5">
        <h1>Find Your Next Ride</h1>
        <p class="lead">Experience the joy of a premium car without the premium price tag!</p>
    </section>

    <div class="row">
        <% featuredVehicles.forEach(vehicle => { %>
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <img src="<%= vehicle.primary_image %>" class="card-img-top" alt="<%= vehicle.model %>">
                    <div class="card-body">
                        <h5 class="card-title"><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h5>
                        <p class="text-primary fw-bold">$<%= vehicle.price.toLocaleString() %></p>
                        <a href="/vehicle/<%= vehicle.id %>" class="btn btn-outline-dark w-100">View Details</a>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</main>
<%- include('partials/footer') %>