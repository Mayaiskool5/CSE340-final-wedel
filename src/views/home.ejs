<%- include('partials/header') %>

<link rel="stylesheet" href="/css/main.css">

<main>
    <section class="text-center mb-5">
        <h1>Find Your Next Ride</h1>
        <p class="lead">Experience the joy of a premium car without the premium price tag!</p>
    </section>

    <div class="featured-vehicles">
        <% if (featuredVehicles && featuredVehicles.length > 0) { %>
            <% featuredVehicles.forEach(vehicle => { %>
                <div class="vehicle-card">
                    <img src="<%= vehicle.image %>" alt="<%= vehicle.name %>">
                    <h2><%= vehicle.make %> <%= vehicle.model %></h2>
                    <p><%= vehicle.description %></p>
                    <a href="/vehicles/<%= vehicle.slug %>">View Details</a>
                </div>
            <% }); %>
        <% } else { %>
            <p>No featured vehicles available at this time.</p>
        <% } %>
    </div>
</main>

<%- include('partials/footer') %>